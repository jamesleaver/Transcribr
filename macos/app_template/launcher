#!/bin/bash
# Transcribr - app launcher
# This file is the Mac app's executable entry point. Everything
# Transcribr needs lives in the current user's Application Support
# folder, resolved here at launch time - the bundle itself is the same
# for every user, so one copy in /Applications serves every account on
# the Mac (each account runs the installer once to set itself up).

set -uo pipefail

APP_SUPPORT="$HOME/Library/Application Support/Transcribr"
VENV="$APP_SUPPORT/venv"
SCRIPT="$APP_SUPPORT/transcribr.py"

# Make Homebrew binaries (especially ffmpeg) visible to the GUI process.
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/local/sbin:$PATH"

# Missing pieces mean this macOS user hasn't been set up yet (or the
# folder was deleted) - either way the remedy is running the installer
# while logged in as this user.
if [ ! -f "$VENV/bin/activate" ] || [ ! -f "$SCRIPT" ]; then
    /usr/bin/osascript -e "display alert \"Transcribr\" message \"Transcribr isn't set up for this macOS user yet.\\n\\nRun the Transcribr installer while logged in as this user to finish setup.\\n\\nIt installs into:\\n$APP_SUPPORT\" as critical"
    exit 1
fi

# shellcheck disable=SC1091
source "$VENV/bin/activate"

# Launch detached so the .app process can exit cleanly. Errors get
# captured to a log file the user can dig out if something goes wrong.
LOG_DIR="$HOME/Library/Logs/Transcribr"
mkdir -p "$LOG_DIR"
LOG="$LOG_DIR/launch.log"

{
    echo "==== $(date) ===="
    # "$@" lets `open -a Transcribr --args --annotate` reach the app.
    "$VENV/bin/python" "$SCRIPT" "$@"
    echo "GUI exited with status $?"
} >> "$LOG" 2>&1
